{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceBaseName": {
      "value": "bot${{RESOURCE_SUFFIX}}"
    },
    "llmProvider": {
      "value": "${{LLM_PROVIDER}}"
    },
    "llmApiKey": {
      "value": "${{SECRET_LLM_API_KEY}}"
    },
    "llmModelName": {
      "value": "${{LLM_MODEL_NAME}}"
    },
    "webAppSKU": {
      "value": "B1"
    },
    "botDisplayName": {
      "value": "ms-teams-bot"
    }
  }
}
