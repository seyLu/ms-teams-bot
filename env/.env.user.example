# Blueprint for secret environment variables.
# Copy this file to `.env.local.user` or `.env.dev.user` depending on your active environment.

# If you're adding a secret value, ALWAYS add the SECRET_ prefix to the name.
# Keys prefixed with `SECRET_` will be masked in Microsoft 365 Agents Toolkit deployment logs.

SECRET_LLM_API_KEY=<your-llm-api-key>
SECRET_BOT_PASSWORD=

# Webhook Secrets (referenced by src/app/tools/webhook/webhook.config.ts)

# Standard Bearer Auth Example
SECRET_N8N_API_KEY=<your-n8n-token>

# Custom Header Auth Example (e.g., x-api-key)
SECRET_CUSTOM_API_KEY=<your-api-gateway-key>

# SharePoint Delta Poller Webhook
SECRET_SHAREPOINT_DELTA_POLLER_WEBHOOK_URL=<your-sharepoint-delta-poller-webhook-url>
