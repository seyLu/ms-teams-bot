# Blueprint for non-secret environment variables.
# Copy this file to `.env.local` or `.env.dev` depending on your active environment.

# Built-in environment variables
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=dev

# Teams Toolkit Provisioned Variables (Usually auto-generated by the toolkit)
BOT_ID=
TEAMS_APP_ID=
BOT_DOMAIN=
BOT_ENDPOINT=

# Deployment Variables (Needed for Azure deployment, e.g., in .env.dev)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP_NAME=
RESOURCE_SUFFIX=
BOT_AZURE_APP_SERVICE_RESOURCE_ID=
TEAMS_APP_TENANT_ID=

# AI Provider Configuration
# Supported LLM_PROVIDERs: openai, claude, gemini, litellm
# Example Model Names:
# - openai: gpt-4o, gpt-4o-mini
# - claude: claude-3-7-sonnet-latest, claude-3-5-sonnet-latest
# - gemini: gemini-2.5-pro, gemini-1.5-pro
#
# For LiteLLM, you must specify the LLM_BASE_URL (optional for other providers):
# NOTE: The deployment toolkit requires this key to exist even if empty.
LLM_BASE_URL=
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
MAX_HISTORY_MESSAGES=20
